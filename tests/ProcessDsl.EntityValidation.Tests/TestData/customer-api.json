{
  "openapi": "3.0.3",
  "info": {
    "title": "Customer API",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {
      "Customer": {
        "type": "object",
        "required": ["id", "name", "email"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string", "minLength": 1 },
          "email": { "type": "string", "format": "email" }
        }
      }
    }
  }
}
